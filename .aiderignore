# =============================================================================
# Build outputs — never relevant
# =============================================================================
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# =============================================================================
# Virtual environment — thousands of files, zero relevance
# =============================================================================
.venv/
venv/
.conda/

# =============================================================================
# Dependencies & lock files — large, noisy, never read
# =============================================================================
uv.lock
requirements.txt
*.lock

# =============================================================================
# IDE & editor artifacts
# =============================================================================
.idea/
.vscode/
.ruff_cache/
.mypy_cache/

# =============================================================================
# Logs & output directories — agent never needs raw logs
# =============================================================================
logs/
output/
results/
temp/
tmp/

# =============================================================================
# Testing artifacts
# =============================================================================
.pytest_cache/
.coverage
htmlcov/

# =============================================================================
# Sample documents — binary blobs (PDFs, DOCXs) not useful for code work
# =============================================================================
sample_documents/

# =============================================================================
# One-off/debug scripts at root — exploratory code, not project source
# =============================================================================
check_gemini_models.py
debug_agent_llm.py
debug_config_loading.py
test_*.py
validate_fixes.py
verify_*.py

# =============================================================================
# CrewAI specific
# =============================================================================
.crewai/
crewai_outputs/
crew_logs/

# =============================================================================
# Environment files — security + never relevant for code
# =============================================================================
.env
.env.*
env_example

# =============================================================================
# Generated/pre-rendered artifacts
# =============================================================================
mas_enterprise_architecture_explorer.html
*.generated.*

# =============================================================================
# CI / pre-commit configs — agent doesn't need to read these
# =============================================================================
.pre-commit-hooks/
.pre-commit-config.yaml
setup-pre-commit.ps1
setup-pre-commit.sh

# =============================================================================
# Git internals
# =============================================================================
.git/
