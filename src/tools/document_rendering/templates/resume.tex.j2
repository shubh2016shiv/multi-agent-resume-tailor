% Document class and font size
\documentclass[a4paper,9pt]{extarticle}

% Packages
\usepackage[utf8]{inputenc}
\usepackage{geometry}
\geometry{letterpaper, margin=0.75in}
\usepackage{titlesec}
\usepackage{enumitem}
\usepackage{hyperref}
\usepackage{tabularx}
\usepackage{fancyhdr}

\usepackage{xcolor}
\usepackage{fontawesome5}

\definecolor{resumeNavy}{HTML}{2F3B4F}
\definecolor{resumeGray}{HTML}{4A5568}
\definecolor{resumeLine}{HTML}{D9DEE8}

\hypersetup{
    colorlinks=true,
    urlcolor=resumeNavy,
    linkcolor=resumeNavy,
    citecolor=resumeNavy
}

% Formatting
\setlist{noitemsep}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}[\titlerule]
\titlespacing*{\section}{0pt}{\baselineskip}{\baselineskip}

\newlength{\skillhang}
\newcommand{\skillcategory}[2]{%
    \par
    \hangindent=1.5em
    \hangafter=1
    \noindent
    \mbox{\textbf{#1:}}~#2%
    \par
    \vspace{3pt}%
}

\ExplSyntaxOn
% \skills{skill1, skill2, skill3} — wraps each skill in \mbox so line breaks
% only occur AFTER commas, never inside a multi-word skill.
\NewDocumentCommand{\skills}{m}
 {
  \seq_clear:N \l_tmpa_seq
  \seq_set_split:Nnn \l_tmpb_seq { , } { #1 }
  \seq_map_inline:Nn \l_tmpb_seq
   {
    \tl_set:Nn \l_tmpa_tl { ##1 }
    \tl_trim_spaces:N \l_tmpa_tl
    \seq_put_right:NV \l_tmpa_seq \l_tmpa_tl
   }
  \seq_pop_right:NN \l_tmpa_seq \l_tmpa_tl
  \seq_map_inline:Nn \l_tmpa_seq { \mbox{##1},~ }
  \exp_args:NV \mbox \l_tmpa_tl
 }
\ExplSyntaxOff

\usepackage{array}
\usepackage{microtype} % better justification and spacing
\pretolerance=1000
\tolerance=2000
\emergencystretch=2em
\hyphenpenalty=10000
\exhyphenpenalty=10000
\brokenpenalty=10000
\renewcommand{\arraystretch}{1.15}

\begin{document}

\pagestyle{fancy}
\renewcommand{\headrulewidth}{0pt}
\fancyhead{}
\fancyhead[L]{<< name | e_tex >>}
\fancyhead[R]{}
\thispagestyle{empty}

% ── Header ───────────────────────────────────────────────────────────────────
\begin{center}
    {\Huge \bfseries \color{resumeNavy} << name | e_tex >>}\\[5pt]
<% if headline %>
    {\large \textsc{\color{resumeGray} << headline | e_tex >>}}\\[8pt]
<% endif %>
    {\small
    \color{resumeGray}
<% if location %>
    \faMapMarker* \hspace{2pt} << location | e_tex >>
    \quad
<% endif %>
    \faEnvelope \hspace{2pt}
    \href{mailto:<< email | e_url >>}{<< email | e_tex >>}
<% if phone %>
    \quad
    \faPhone* \hspace{2pt}
    \href{tel:<< phone | e_url >>}{<< phone | e_tex >>}
<% endif %>
<% if website %>
    \quad
    \faGlobe \hspace{2pt}
    \href{<< website | e_url >>}{Portfolio}
<% endif %>
    }
\end{center}

<% for section in sections %>
<% if section == 'summary' %>
\section*{SUMMARY}
\noindent
<< summary | e_tex >>

<% elif section == 'skills' %>
\section*{SKILLS}
<% for group in skill_groups %>
\skillcategory{<< group.category | e_tex >>}{\skills{<% for s in group.skills %><< s | e_tex >><% if not loop.last %>, <% endif %><% endfor %>}}
<% endfor %>

<% elif section == 'experience' %>
\section*{EXPERIENCE}
<% for exp in experiences %>
\noindent
\textbf{<< exp.company | e_tex >>} \hfill << exp.location | e_tex >>\\
\textit{<< exp.job_title | e_tex >>} \hfill << exp.date_range | e_tex >>
<% if exp.achievements %>
\begin{itemize}
<% for bullet in exp.achievements %>
    \item << bullet | e_tex >>
<% endfor %>
\end{itemize}
<% endif %>
\vspace{2pt}

<% endfor %>
<% elif section == 'education' %>
\section*{EDUCATION}
<% for edu in education %>
\noindent
\textbf{<< edu.institution | e_tex >>} \hfill << edu.year >>\\
<< edu.degree | e_tex >><% if edu.field %> in << edu.field | e_tex >><% endif %>

\vspace{4pt}
<% endfor %>

<% elif section == 'certifications' %>
\section*{CERTIFICATIONS}
<% for cert in certifications %>
\noindent
\textbf{<< cert | e_tex >>}\\
<% endfor %>

<% elif section == 'languages' %>
\section*{LANGUAGES}
\noindent
<% for lang in languages %><< lang | e_tex >><% if not loop.last %>, <% endif %><% endfor %>

<% endif %>
<% endfor %>
\end{document}
